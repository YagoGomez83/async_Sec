# ============================================================
#  Async Security Processor — Environment Variables Template
#  Copy this file to .env and fill in your own values.
#  NEVER commit .env to version control.
# ============================================================

# --- API Authentication ---
# Generate with: openssl rand -hex 32
API_KEY=change_me_generate_with_openssl_rand_hex_32

# --- RabbitMQ (Message Broker) ---
RABBITMQ_USER=sec_admin
RABBITMQ_PASS=change_me_strong_password
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672

# --- Redis (Result Backend) ---
REDIS_PASS=change_me_another_strong_password
REDIS_HOST=localhost
REDIS_PORT=6379

# --- PostgreSQL (Audit Database) ---
POSTGRES_USER=sec_db_admin
POSTGRES_PASSWORD=change_me_secure_db_password
POSTGRES_DB=security_scans_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Logging ---
# LOG_LEVEL=INFO           # DEBUG | INFO | WARNING | ERROR | CRITICAL
# LOG_JSON=false           # Set to true in production for JSON output (Docker / ELK / Loki)
