.pytest_cache/
.coverage
htmlcov/
pytest.ini

# ── Documentation ──────────────────────────────────────────────────────────────
README.md
*.md

# ── IDE / editor ───────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── OS noise ───────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Logs ───────────────────────────────────────────────────────────────────────
*.log
logs/
