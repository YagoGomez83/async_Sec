# ── Secrets & environment ──────────────────────────────────────────────────────
.env
*.pem
*.key
*.p12
*.pfx

# ── Version control ────────────────────────────────────────────────────────────
.git/
.gitignore
.github/

# ── Virtual environments (use pip install inside the image instead) ────────────
venv/
.venv/
env/

